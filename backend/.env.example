DB_TYPE=sqlite
DB_DATABASE=tuji_dev.db

JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

PORT=3000
NODE_ENV=development

# 豆包大模型 API Key (可选)
DOUBAO_API_KEY=
DOUBAO_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-evolving

# 高德地图 API Key (可选)
AMAP_KEY=
